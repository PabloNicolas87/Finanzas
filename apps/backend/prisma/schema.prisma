// prisma/schema.prisma
// Finanzas Personales — Modelo "Bolsillos Separados, Economía Compartida"
// Usuarios: Pablo (PJ - MEI) y Rocío (PF)

generator client {
  provider = "prisma-client-js"
}

// En Prisma 7, la URL de conexión se configura en prisma.config.ts
// No se declara `url` aquí — el driver adapter la gestiona.
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

/// Tipo de persona del usuario
enum UserType {
  PJ // Pessoa Jurídica (Pablo - MEI)
  PF // Pessoa Física   (Rocío)
}

/// Tipo de movimiento en una transacción
enum TransactionType {
  INCOME // Ingreso
  EXPENSE // Egreso
  TRANSFER // Transferencia interna (reservado para uso futuro)
}

/// Estado de la transacción (Checklist / Cuentas por Pagar)
enum TransactionStatus {
  PENDING
  PAID
}

/// Tipo de factura MEI (Genuina vs Interna Pendiente)
enum MeiInvoiceType {
  GENUINE
  INTERNAL_PENDING
}

/// Dominios de categorías
enum CategoryType {
  INCOME
  EXPENSE
  CREDIT_CARD
}

// ─────────────────────────────────────────────
//  MODELO: User
//  Representa a Pablo (PJ) y Rocío (PF).
//  Solo habrá 2 registros en producción.
// ─────────────────────────────────────────────

model User {
  id    Int      @id @default(autoincrement())
  name  String
  email String   @unique
  type  UserType // PJ o PF

  /// Límite anual de facturación MEI (solo aplica para type = PJ).
  /// En 2024: 81.000 BRL. Null si type = PF.
  meiAnnualLimit Decimal? @db.Decimal(12, 2)

  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────
//  MODELO: Account
//  Cuenta bancaria de un usuario.
//  Ej: "Santander PJ" de Pablo, "Bradesco PF" de Rocío.
// ─────────────────────────────────────────────

model Account {
  id       Int    @id @default(autoincrement())
  userId   Int
  bankName String // Nombre del banco (Ej: "Santander", "Bradesco")
  name     String // Alias descriptivo (Ej: "Corriente Santander PJ")

  /// Saldo actual. Se actualiza atómicamente en cada transacción.
  balance Decimal @default(0) @db.Decimal(12, 2)

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  creditCards CreditCard[]

  @@map("accounts")
}

// ─────────────────────────────────────────────
//  MODELO: CreditCard
//  Tarjeta de crédito asociada a una cuenta bancaria (Para pago del resumen).
// ─────────────────────────────────────────────

model CreditCard {
  id         Int    @id @default(autoincrement())
  accountId  Int
  name       String // Ej: "Visa Black", "Nubank"
  closingDay Int // Día de cierre (Ej: 20)
  dueDay     Int // Día de vencimiento (Ej: 28)

  account      Account               @relation(fields: [accountId], references: [id])
  transactions Transaction[]
  statements   CreditCardStatement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("credit_cards")
}

// ─────────────────────────────────────────────
//  MODELO: CreditCardStatement
//  Consolidado mensual de una tarjeta de crédito.
// ─────────────────────────────────────────────

model CreditCardStatement {
  id           Int               @id @default(autoincrement())
  creditCardId Int
  month        Int // 0-indexed (Ej: 0 = Enero)
  year         Int // Ej: 2026
  totalAmount  Decimal           @db.Decimal(12, 2)
  status       TransactionStatus @default(PENDING) // PAID cuando se pague todo el resumen
  dueDate      DateTime

  creditCard CreditCard @relation(fields: [creditCardId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([creditCardId, month, year])
  @@map("credit_card_statements")
}

// ─────────────────────────────────────────────
//  MODELO: Category
//  GLOBAL — No está atada a ningún usuario.
//  Esto permite sumar gastos de Pablo Y Rocío en el mismo
//  dashboard mensual "Gastos de la Casa".
//  Ejemplos: "Alquiler", "Supermercado", "Luz", "Factura MEI"
// ─────────────────────────────────────────────

model Category {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  icon    String? // Emoji o ícono (Ej: "🏠", "🛒")
  isFixed Boolean      @default(false) // Diferencia gastos fijos de variables
  type    CategoryType @default(EXPENSE)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// ─────────────────────────────────────────────
//  MODELO: Transaction
//  El corazón del sistema. Registra TODOS los movimientos.
//
//  Flujo MEI (operación atómica en processMeiInvoice):
//    Se crean DOS registros en una sola Prisma $transaction:
//      1. EXPENSE en cuenta de Rocío  → isMeiInvoice = false
//      2. INCOME  en cuenta de Pablo  → isMeiInvoice = true  ← AUDITABLE
//    Ambas comparten el mismo meiInvoiceGroupId (UUID) para trazabilidad.
// ─────────────────────────────────────────────

model Transaction {
  id          Int               @id @default(autoincrement())
  accountId   Int
  categoryId  Int
  amount      Decimal           @db.Decimal(12, 2)
  type        TransactionType // INCOME | EXPENSE | TRANSFER
  status      TransactionStatus @default(PENDING)
  description String?
  date        DateTime          @default(now())
  dueDate     DateTime? // Fecha de vencimiento esperada (para Accounts Payable)

  /// Para transferencias internas (TRANSFER)
  toAccountId Int?

  /// TRUE solo en el ingreso de Pablo que proviene de una factura MEI.
  /// La suma anual de estos registros NO debe superar meiAnnualLimit.
  isMeiInvoice Boolean @default(false)

  /// UUID que agrupa el par (EXPENSE Rocío + INCOME Pablo) de un invoice MEI.
  /// Permite auditar y anular un invoice completo si fuera necesario.
  meiInvoiceGroupId String?

  /// Tipo de factura MEI (Genuina o Interna)
  meiInvoiceType    MeiInvoiceType?

  /// Relaciones para pago con Tarjeta de Crédito (Installments)
  creditCardId      Int?
  installmentNumber Int? // (Ej: 1)
  totalInstallments Int? // (Ej: 3, para indicar 1/3)
  creditCardGroupId String? // UUID para agrupar todas las cuotas de una compra original
  purchaseDate      DateTime? // La fecha real en la que se pasó la tarjeta

  account    Account     @relation(fields: [accountId], references: [id])
  category   Category    @relation(fields: [categoryId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Índice para consultas de auditoría MEI (filtrar por flag + año)
  @@index([isMeiInvoice, date])
  // Índice para agrupar el par de transacciones de un mismo invoice
  @@index([meiInvoiceGroupId])
  // Índice para agrupar las cuotas de una misma compra con TC
  @@index([creditCardGroupId])
  @@map("transactions")
}
